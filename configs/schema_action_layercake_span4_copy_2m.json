{
  "name": "schema_action_layercake_span4_copy_2m",
  "model": {
    "patch_size": 2,
    "span_width": 4,
    "d_byte": 32,
    "d_model": 224,
    "d_abi": 128,
    "layers": 1,
    "heads": 4,
    "max_patches": 128,
    "continuous_local": false,
    "direct_global_context": true,
    "local_decoder": "span_patch_decoder",
    "local_width": 224,
    "modern_blocks": true,
    "fused_attention": true,
    "dropout": 0.05,
    "qk_norm": true,
    "global_block": "sparse_state_patch",
    "sparse_state_local_window": 16,
    "sparse_state_dilated_offsets": [16, 24, 32, 48],
    "sparse_state_chunk_size": 8,
    "context_buckets": 2048,
    "context_order": 4,
    "transition_logit_scale": 1.0,
    "context_logit_scale": 1.0,
    "trainable_prior_gates": true,
    "trainable_transition_head": true,
    "trainable_context_head": true,
    "copy_transducer": true,
    "copy_transducer_dim": 64,
    "copy_transducer_scale": 5.0,
    "copy_transducer_window": 256,
    "domain_cache_order": 0,
    "domain_cache_logit_scale": 0.0,
    "domain_cache_override": false
  },
  "training": {
    "answer_loss_weight": 5.0,
    "answer_only_loss": true,
    "copy_loss_weight": 0.2,
    "span_loss_weight": 0.5,
    "betas": [0.9, 0.95],
    "byte_prior_max_bytes": 4000000,
    "byte_prior_smoothing": 0.1,
    "data_roots": ["data/schema_action_domain/train.jsonl"],
    "device": "cuda",
    "eval_batches": 8,
    "eval_bytes": 65536,
    "eval_data_roots": ["data/schema_action_domain/eval.jsonl"],
    "grad_accum_steps": 1,
    "include_suffixes": [".jsonl"],
    "initialize_byte_priors_from_corpus": true,
    "initialize_domain_cache_from_corpus": false,
    "keep_last_n": 1,
    "log_interval": 200,
    "lr": 0.0005,
    "lr_decay_steps": 6000,
    "matmul_precision": "high",
    "metrics_path": "training_metrics.json",
    "micro_batch_size": 8,
    "min_lr": 0.00006,
    "out_dir": "runs_experiment/schema_action_layercake_span4_copy_2m",
    "read_block_bytes": 1048576,
    "save_interval": 2000,
    "save_optimizer": false,
    "seed": 2414,
    "seq_len": 256,
    "steps": 6000,
    "warmup_steps": 80,
    "weight_decay": 0.01
  }
}
