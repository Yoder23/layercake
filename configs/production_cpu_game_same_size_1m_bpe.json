{
  "name": "production_cpu_game_same_size_1m_bpe",
  "description": "Same-size 1M-class BPE transformer production CPU/game gate baseline.",
  "tokenizer": {
    "vocab_size": 4096,
    "model_type": "bpe",
    "byte_fallback": true
  },
  "model": {
    "d_model": 128,
    "layers": 1,
    "heads": 4,
    "ff_mult": 4,
    "dropout": 0.05
  },
  "training": {
    "device": "cuda",
    "matmul_precision": "high",
    "seq_len": 256,
    "micro_batch_size": 4,
    "grad_accum_steps": 1,
    "steps": 2000,
    "lr": 0.0004,
    "min_lr": 0.00008,
    "warmup_steps": 100,
    "lr_decay_steps": 2000,
    "weight_decay": 0.01,
    "log_interval": 50,
    "save_optimizer": false,
    "metrics_path": "training_metrics.json",
    "corpus_bytes": 2000000,
    "eval_bytes": 100000,
    "eval_batches": 8,
    "read_block_bytes": 1048576,
    "include_suffixes": [".jsonl", ".json", ".txt", ".md", ".csv"],
    "data_roots": [
      "../layercakeogwithdecoder/data/v6/redpajama_english_train.jsonl",
      "./data/curriculum/english_school_curriculum.txt",
      "./data/curriculum/companion_dialogue_curriculum.txt"
    ],
    "out_dir": "runs_experiment/production_cpu_game_same_size_1m_bpe"
  }
}
