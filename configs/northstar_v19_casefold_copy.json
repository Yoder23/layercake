{
  "extends": "northstar_v18_supervised_context_copy.json",
  "name": "northstar_v19_casefold_copy",
  "description": "Train the contextual pointer with ASCII uppercase-to-lowercase copy mass so canonical lowercase identifiers are supervised directly from title-cased prompt values.",
  "model": {
    "patch_generation_lowercase_copy": true
  },
  "training": {
    "seed": 13211,
    "steps": 68000,
    "lr": 0.00005,
    "min_lr": 0.000005,
    "warmup_steps": 100,
    "lr_decay_steps": 5900,
    "lr_step_offset": 62000,
    "patch_prediction_copy_loss_weight": 1.0,
    "resume_from": "runs_experiment/northstar_v18_supervised_context_copy/latest.pt",
    "resume_strict": true,
    "log_interval": 500,
    "save_interval": 3000,
    "eval_seed": 13212,
    "out_dir": "runs_experiment/northstar_v19_casefold_copy"
  }
}
