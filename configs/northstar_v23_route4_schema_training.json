{
  "extends": "northstar_v23_shared3_routed_tail.json",
  "name": "northstar_v23_route4_schema_training",
  "description": "Isolation/convergence proof: train only routed domain cake 4 with the generation-aligned patch objective while the v22-compatible route 0 and shared foundation remain frozen.",
  "training": {
    "seed": 13331,
    "steps": 71000,
    "lr": 0.0002,
    "min_lr": 0.00002,
    "warmup_steps": 40,
    "lr_decay_steps": 1000,
    "lr_step_offset": 70000,
    "cake_route": 4,
    "cake_sparse_optimizer": true,
    "domain_cake_training_only": true,
    "patch_prediction_loss_weight": 1.0,
    "patch_prediction_answer_start_only": true,
    "log_interval": 50,
    "save_interval": 500,
    "save_optimizer": false,
    "data_mix": [
      {
        "name": "schema_action_grounding",
        "weight": 1.0,
        "include_suffixes": [".jsonl"],
        "row_preserve_jsonl_examples": true,
        "data_roots": ["data/schema_action_domain/train.jsonl"]
      }
    ],
    "eval_data_roots": [],
    "resume_from": "runs_experiment/northstar_v23_shared3_routed_tail/migrated_v22.pt",
    "out_dir": "runs_experiment/northstar_v23_route4_schema_training"
  }
}
