{
  "name": "layercake_byte_500m_core",
  "description": "Tokenizer-free byte-patch LayerCake core (~502M params)",
  "model": {
    "patch_size": 2,
    "d_byte": 96,
    "d_model": 1280,
    "d_abi": 320,
    "layers": 24,
    "heads": 16,
    "max_patches": 1024,
    "continuous_local": false,
    "direct_global_context": true,
    "local_decoder": "window_transformer",
    "local_layers": 4,
    "local_width": 768,
    "modern_blocks": true,
    "fused_attention": true,
    "local_window": 64,
    "patch_unit_buckets": 0,
    "dropout": 0.1,
    "qk_norm": true,
    "global_block": "attention"
  },
  "training": {
    "device": "cuda",
    "matmul_precision": "high",
    "dataloader_workers": 2,
    "pin_memory": true,
    "persistent_workers": true,
    "compile_model": false,
    "optimizer_fused": true,
    "seq_len": 2048,
    "micro_batch_size": 2,
    "grad_accum_steps": 16,
    "steps": 100000,
    "lr": 0.0001,
    "weight_decay": 0.01,
    "log_interval": 50,
    "save_interval": 1000,
    "keep_last_n": 1,
    "save_optimizer": false,
    "metrics_path": "training_metrics.json",
    "throughput_guard": {
      "warmup_steps": 100,
      "max_projected_hours": 168,
      "abort_on_fail": true
    },
    "include_suffixes": [
      ".jsonl",
      ".json",
      ".txt",
      ".md",
      ".csv"
    ],
    "data_roots": [
      "../layercakeogwithdecoder/data/v6/redpajama_english_train.jsonl",
      "../layercakeogwithdecoder/data/v6/redpajama_english_eval.jsonl",
      "../data"
    ],
    "out_dir": "runs_experiment/byte_500m_core"
  }
}
