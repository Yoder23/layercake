{
  "name": "production_companion_15m_layercake_redpajama_game_phase3",
  "description": "Phase-3 domain-polish continuation for the 15M LayerCake companion core. Resumes phase 2 after expanding companion-response coverage for ad-hoc game-loop phrasing.",
  "model": {
    "patch_size": 2,
    "d_byte": 64,
    "d_model": 512,
    "d_abi": 160,
    "layers": 6,
    "heads": 8,
    "max_patches": 2048,
    "continuous_local": false,
    "direct_global_context": true,
    "local_decoder": "abi_patch_cell",
    "local_layers": 0,
    "conv_layers": 0,
    "local_width": 160,
    "modern_blocks": true,
    "fused_attention": true,
    "local_window": 32,
    "ngram_buckets": 1024,
    "dropout": 0.05,
    "qk_norm": true,
    "global_block": "selective_state_patch",
    "abi_patch_cell_static_generation": false,
    "abi_patch_cell_global_update_interval": 16,
    "abi_patch_cell_fast_global_decode": true,
    "abi_patch_cell_fast_local_runtime": false,
    "abi_patch_cell_lightweight_context_update": false,
    "abi_patch_cell_lightweight_context_blend": 0.15,
    "generation_min_word_chars": 0,
    "generation_repeat_suppression_window": 0,
    "generation_repeat_suppression_scale": 0.0,
    "context_buckets": 32768,
    "context_order": 8,
    "context_logit_scale": 0.4,
    "transition_logit_scale": 0.2,
    "domain_cache_order": 16,
    "domain_cache_logit_scale": 1.0,
    "domain_cache_override": true,
    "trainable_prior_gates": true,
    "trainable_transition_head": false,
    "trainable_context_head": false
  },
  "training": {
    "device": "cuda",
    "seed": 4236,
    "matmul_precision": "high",
    "seq_len": 2048,
    "micro_batch_size": 2,
    "grad_accum_steps": 1,
    "steps": 11000,
    "resume_from": "runs_experiment/production_companion_15m_layercake_redpajama_game_phase2/latest.pt",
    "lr": 0.00004,
    "min_lr": 0.00003,
    "warmup_steps": 0,
    "lr_decay_steps": 1000,
    "lr_step_offset": 10000,
    "weight_decay": 0.01,
    "teacher_local_decoder": "window_transformer",
    "student_local_decoder": "abi_patch_cell",
    "distill_loss_weight": 0.0,
    "distill_interval": 4,
    "distill_until_step_ratio": 0.25,
    "log_interval": 250,
    "save_interval": 1000,
    "initialize_byte_priors_from_corpus": true,
    "byte_prior_max_bytes": 8388608,
    "byte_prior_smoothing": 0.05,
    "initialize_domain_cache_from_corpus": true,
    "domain_cache_max_bytes": 7000000,
    "domain_cache_smoothing": 0.000001,
    "domain_cache_max_entries": 350000,
    "domain_cache_min_confidence": 0.999,
    "domain_cache_high_confidence_boost": 1.0,
    "keep_last_n": 1,
    "save_optimizer": false,
    "metrics_path": "training_metrics.json",
    "read_block_bytes": 1048576,
    "include_suffixes": [".jsonl", ".json", ".txt", ".md", ".csv"],
    "eval_bytes": 200000,
    "eval_batches": 16,
    "eval_seed": 9878,
    "data_roots": [
      "./data/game_domains/ember-road.companion_responses.txt",
      "./data/game_domains/ember-road.rulebook.repeated.txt",
      "./data/game_domains/ember-road.instructions.txt",
      "./data/game_domains/ember-road.rulebook.json",
      "./data/curriculum/companion_dialogue_curriculum.txt",
      "./data/curriculum/english_school_curriculum.txt",
      "../layercakeogwithdecoder/data/v6/redpajama_english_train.jsonl"
    ],
    "eval_data_roots": [
      "./data/game_domains/ember-road.companion_responses.txt",
      "./data/game_domains/ember-road.instructions.txt",
      "./data/game_domains/ember-road.rulebook.json",
      "./data/curriculum/companion_dialogue_curriculum.txt",
      "../layercakeogwithdecoder/data/v6/redpajama_english_eval.jsonl"
    ],
    "out_dir": "runs_experiment/production_companion_15m_layercake_redpajama_game_phase3"
  }
}
