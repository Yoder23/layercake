{
  "name": "production_cpu_game_5m_bpe_rigorous",
  "description": "Longer trained-checkpoint 5M-class BPE transformer baseline with identical held-out eval corpus.",
  "tokenizer": {
    "vocab_size": 4096,
    "model_type": "bpe",
    "byte_fallback": true
  },
  "model": {
    "d_model": 384,
    "layers": 1,
    "heads": 4,
    "ff_mult": 4,
    "dropout": 0.05
  },
  "training": {
    "device": "cuda",
    "seed": 1234,
    "matmul_precision": "high",
    "seq_len": 256,
    "micro_batch_size": 4,
    "grad_accum_steps": 1,
    "steps": 10000,
    "lr": 0.0004,
    "min_lr": 0.00008,
    "warmup_steps": 500,
    "lr_decay_steps": 10000,
    "weight_decay": 0.01,
    "log_interval": 250,
    "save_optimizer": false,
    "metrics_path": "training_metrics.json",
    "corpus_bytes": 20000000,
    "eval_bytes": 200000,
    "eval_batches": 16,
    "read_block_bytes": 1048576,
    "include_suffixes": [".jsonl", ".json", ".txt", ".md", ".csv"],
    "data_roots": [
      "../layercakeogwithdecoder/data/v6/redpajama_english_train.jsonl",
      "./data/curriculum/english_school_curriculum.txt",
      "./data/curriculum/companion_dialogue_curriculum.txt"
    ],
    "eval_data_roots": [
      "./data/game_domains/ember-road.rulebook.repeated.txt"
    ],
    "out_dir": "runs_experiment/production_cpu_game_5m_bpe_rigorous"
  }
}
