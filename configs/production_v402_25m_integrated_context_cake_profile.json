{
  "name": "production_v402_25m_integrated_context_cake_profile",
  "description": "Exact-parameter 25M LayerCake profile gate: frozen corpus-built byte-context cake plus compact patch-4 sparse-state neural core.",
  "model": {
    "patch_size": 4,
    "d_byte": 32,
    "d_model": 224,
    "d_abi": 128,
    "layers": 4,
    "heads": 8,
    "max_patches": 256,
    "continuous_local": false,
    "direct_global_context": true,
    "local_decoder": "window_transformer",
    "local_layers": 1,
    "conv_layers": 2,
    "local_width": 224,
    "modern_blocks": true,
    "fused_attention": true,
    "local_window": 32,
    "dropout": 0.0,
    "qk_norm": true,
    "global_block": "sparse_state_patch",
    "sparse_state_local_window": 16,
    "sparse_state_dilated_offsets": [16, 24, 32, 48],
    "sparse_state_chunk_size": 8,
    "context_buckets": 84577,
    "context_order": 3,
    "transition_logit_scale": 0.25,
    "context_logit_scale": 0.75,
    "trainable_prior_gates": false,
    "trainable_transition_head": false,
    "trainable_context_head": false
  },
  "training": {
    "device": "cuda",
    "seed": 2402,
    "matmul_precision": "high",
    "dataloader_workers": 0,
    "pin_memory": true,
    "compile_model": false,
    "optimizer_fused": true,
    "seq_len": 512,
    "micro_batch_size": 32,
    "grad_accum_steps": 1,
    "steps": 20,
    "lr": 0.0006,
    "min_lr": 0.00006,
    "warmup_steps": 4,
    "lr_decay_steps": 20,
    "weight_decay": 0.01,
    "log_interval": 5,
    "save_interval": 20,
    "keep_last_n": 1,
    "save_optimizer": false,
    "metrics_path": "training_metrics.json",
    "read_block_bytes": 1048576,
    "include_suffixes": [".bin"],
    "data_roots": [
      "runs_experiment/production_v392_corpus/train.bin"
    ],
    "eval_data_roots": [
      "runs_experiment/production_v392_corpus/eval.bin"
    ],
    "eval_bytes": 1000000,
    "eval_batches": 32,
    "eval_seed": 2403,
    "initialize_byte_priors_from_corpus": true,
    "byte_prior_max_bytes": 40000000,
    "byte_prior_smoothing": 0.25,
    "out_dir": "runs_experiment/production_v402_25m_integrated_context_cake_profile"
  }
}
