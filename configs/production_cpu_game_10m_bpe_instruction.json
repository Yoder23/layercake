{
  "name": "production_cpu_game_10m_bpe_instruction",
  "description": "10M-class BPE transformer baseline trained on the same game-domain instruction/rulebook corpus for the 2M LayerCake scale-up rematch.",
  "tokenizer": {
    "vocab_size": 3644,
    "model_type": "bpe",
    "byte_fallback": true
  },
  "model": {
    "d_model": 320,
    "layers": 6,
    "heads": 4,
    "ff_mult": 4,
    "dropout": 0.05
  },
  "training": {
    "device": "cuda",
    "seed": 2234,
    "matmul_precision": "high",
    "seq_len": 256,
    "micro_batch_size": 1,
    "grad_accum_steps": 4,
    "steps": 10000,
    "lr": 0.00035,
    "min_lr": 0.00007,
    "warmup_steps": 500,
    "lr_decay_steps": 10000,
    "weight_decay": 0.01,
    "log_interval": 250,
    "save_optimizer": false,
    "metrics_path": "training_metrics.json",
    "corpus_bytes": 20000000,
    "eval_bytes": 4096,
    "eval_batches": 16,
    "read_block_bytes": 1048576,
    "include_suffixes": [".jsonl", ".json", ".txt", ".md", ".csv"],
    "data_roots": [
      "./data/game_domains/ember-road.instructions.txt",
      "./data/game_domains/ember-road.rulebook.repeated.txt"
    ],
    "eval_data_roots": [
      "./data/game_domains/ember-road.instructions.txt"
    ],
    "out_dir": "runs_experiment/production_cpu_game_10m_bpe_instruction"
  }
}
