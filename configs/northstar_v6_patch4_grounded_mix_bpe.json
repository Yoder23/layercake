{
  "name": "northstar_v6_patch4_grounded_mix_bpe",
  "description": "Matched same-data BPE transformer comparator for northstar_v6_patch4_grounded_mix_layercake.",
  "tokenizer": {
    "vocab_size": 4096,
    "model_type": "bpe",
    "byte_fallback": true
  },
  "model": {
    "d_model": 352,
    "layers": 8,
    "heads": 8,
    "ff_mult": 4,
    "dropout": 0.05
  },
  "training": {
    "device": "cuda",
    "seed": 13060,
    "matmul_precision": "high",
    "seq_len": 384,
    "micro_batch_size": 4,
    "grad_accum_steps": 1,
    "steps": 2000,
    "lr": 0.0002,
    "min_lr": 0.00004,
    "warmup_steps": 80,
    "lr_decay_steps": 2000,
    "weight_decay": 0.01,
    "log_interval": 100,
    "save_optimizer": false,
    "metrics_path": "training_metrics.json",
    "corpus_bytes": 24000000,
    "eval_bytes": 1000000,
    "eval_batches": 32,
    "read_block_bytes": 1048576,
    "mix_block_bytes": 16384,
    "include_suffixes": [".jsonl", ".json", ".txt", ".md", ".csv"],
    "data_mix": [
      {
        "name": "lm_replay",
        "weight": 0.74,
        "include_suffixes": [".jsonl", ".json", ".txt", ".md", ".csv"],
        "data_roots": [
          "./data/game_domains/ember-road.companion_train_expanded_v1.txt",
          "./data/game_domains/ember-road.companion_train_expanded_v1.txt",
          "./data/game_domains/ember-road.companion_train_expanded_v1.txt",
          "./data/game_domains/ember-road.companion_responses.txt",
          "./data/game_domains/ember-road.instructions.txt",
          "./data/game_domains/ember-road.rulebook.repeated.txt",
          "./data/curriculum/companion_dialogue_curriculum.txt",
          "./data/curriculum/english_school_curriculum.txt",
          "../layercakeogwithdecoder/data/v6/redpajama_english_train.jsonl"
        ]
      },
      {
        "name": "question_relevance",
        "weight": 0.13,
        "include_suffixes": [".jsonl"],
        "row_preserve_jsonl_examples": true,
        "data_roots": ["data/question_relevance/question_relevance_train.jsonl"]
      },
      {
        "name": "schema_action_grounding",
        "weight": 0.13,
        "include_suffixes": [".jsonl"],
        "row_preserve_jsonl_examples": true,
        "data_roots": ["data/schema_action_domain/train.jsonl"]
      }
    ],
    "eval_data_roots": [
      "../layercakeogwithdecoder/data/v6/redpajama_english_eval.jsonl"
    ],
    "out_dir": "runs_experiment/northstar_v6_patch4_grounded_mix_bpe"
  }
}
