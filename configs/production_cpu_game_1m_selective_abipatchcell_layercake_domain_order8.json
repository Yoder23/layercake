{
  "name": "production_cpu_game_1m_selective_abipatchcell_layercake_domain_order8",
  "description": "Domain-adapted 1M ABI patch-cell LayerCake with higher-order byte-context prior for BPB/generalization recovery.",
  "model": {
    "patch_size": 2,
    "d_byte": 32,
