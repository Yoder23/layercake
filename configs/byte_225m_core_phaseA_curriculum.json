{
  "name": "layercake_byte_225m_core_phaseA_curriculum",
  "description": "Fast curriculum bootstrap for fluent companion behavior (core remains game-clean)",
  "model": {
    "patch_size": 2,
    "d_byte": 64,
    "d_model": 1024,
    "d_abi": 256,
    "layers": 16,
    "heads": 16,
    "max_patches": 1024,
    "continuous_local": false,
    "direct_global_context": true,
    "local_decoder": "window_transformer",
    "local_layers": 4,
    "local_width": 640,
    "modern_blocks": true,
    "fused_attention": true,
    "local_window": 64,
    "patch_unit_buckets": 0,
    "dropout": 0.1,
    "qk_norm": true,
    "global_block": "attention"
  },
  "training": {
    "device": "cuda",
    "matmul_precision": "high",
    "dataloader_workers": 2,
    "pin_memory": true,
    "persistent_workers": true,
    "compile_model": false,
    "optimizer_fused": true,
    "seq_len": 512,
    "micro_batch_size": 2,
    "grad_accum_steps": 8,
    "steps": 20000,
    "lr": 0.0002,
    "min_lr": 0.00003,
    "warmup_steps": 800,
    "lr_decay_steps": 19200,
    "lr_step_offset": 0,
    "weight_decay": 0.01,
    "log_interval": 50,
    "save_interval": 1000,
    "keep_last_n": 1,
    "save_optimizer": false,
    "metrics_path": "training_metrics.json",
    "throughput_guard": {
      "warmup_steps": 100,
      "max_projected_hours": 72,
      "abort_on_fail": true
    },
    "read_block_bytes": 1048576,
    "include_suffixes": [
      ".jsonl",
      ".json",
      ".txt",
      ".md",
      ".csv"
    ],
    "data_roots": [
      "../layercakeogwithdecoder/data/v6/redpajama_english_train.jsonl",
      "./data/curriculum/english_school_curriculum.txt",
      "./data/curriculum/english_school_curriculum.txt",
      "./data/curriculum/companion_dialogue_curriculum.txt"
    ],
    "out_dir": "runs_experiment/byte_225m_core_phaseA_curriculum"
  }
}
