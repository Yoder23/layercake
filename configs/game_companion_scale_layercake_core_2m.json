{
  "name": "game_companion_scale_layercake_core_2m",
  "description": "2M-class LayerCake core trained on the same English/game companion corpus, with game facts also available as a portable domain layer at evaluation time.",
  "model": {
    "patch_size": 2,
    "span_width": 64,
    "d_byte": 24,
    "d_model": 224,
    "d_abi": 128,
    "layers": 1,
    "heads": 4,
    "max_patches": 256,
    "continuous_local": false,
    "direct_global_context": true,
    "local_decoder": "span_patch_decoder",
    "local_width": 224,
    "modern_blocks": true,
    "fused_attention": true,
    "dropout": 0.04,
    "qk_norm": true,
    "global_block": "sparse_state_patch",
    "sparse_state_local_window": 16,
    "sparse_state_dilated_offsets": [16, 24, 32, 48],
    "sparse_state_chunk_size": 8,
    "context_buckets": 4096,
    "context_order": 4,
    "transition_logit_scale": 1.0,
    "context_logit_scale": 1.0,
    "trainable_prior_gates": true,
    "trainable_transition_head": true,
    "trainable_context_head": true,
    "copy_transducer": false,
    "domain_cache_order": 0,
    "domain_cache_logit_scale": 0.0,
    "domain_cache_override": false
  },
  "training": {
    "device": "cuda",
    "seed": 72013,
    "matmul_precision": "high",
    "seq_len": 512,
    "micro_batch_size": 8,
    "grad_accum_steps": 1,
    "steps": 2000,
    "lr": 0.00045,
    "min_lr": 0.00005,
    "warmup_steps": 100,
    "lr_decay_steps": 2000,
    "weight_decay": 0.01,
    "log_interval": 100,
    "save_interval": 2000,
    "keep_last_n": 1,
    "save_optimizer": false,
    "metrics_path": "training_metrics.json",
    "eval_bytes": 65536,
    "eval_batches": 8,
    "read_block_bytes": 1048576,
    "include_suffixes": [".jsonl", ".json", ".txt", ".md", ".csv"],
    "data_roots": [
      "./data/curriculum/english_school_curriculum.txt",
      "./data/curriculum/companion_dialogue_curriculum.txt",
      "./data/game_domains/ember-road.rulebook.json",
      "./data/game_domains/ember-road.instructions.txt",
      "./data/game_domains/ember-road.companion_responses.txt"
    ],
    "eval_data_roots": [
      "./data/game_domains/ember-road.rulebook.json",
      "./data/game_domains/ember-road.instructions.txt"
    ],
    "out_dir": "runs_experiment/game_companion_scale_layercake_core_2m"
  }
}
