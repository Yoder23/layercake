{
  "name": "northstar_v6_patch4_grounded_mix_layercake",
  "description": "Northstar-v6 fair-neural LayerCake candidate: known fast patch-4 generation path with weighted LM replay, question relevance, and schema/action grounding. No structured heads or direct answer caches.",
  "model": {
    "patch_size": 4,
    "d_byte": 48,
    "d_model": 384,
    "d_abi": 128,
    "layers": 4,
    "heads": 8,
    "max_patches": 64,
    "continuous_local": true,
    "direct_global_context": true,
    "ngram_buckets": 0,
    "local_decoder": "window_transformer",
    "conv_layers": 4,
    "local_layers": 4,
    "local_width": 0,
    "dropout": 0.0,
    "qk_norm": false,
    "patch_encoder_layers": 0,
    "patch_encoder_window": 16,
    "mod_layers": 0,
    "mod_capacity": 0.5,
    "mod_group_size": 8,
    "mod_share_weights": false,
    "local_window": 16,
    "coarse_patch_size": 0,
    "coarse_layers": 0,
    "global_conv_layers": 0,
    "global_gru_layers": 0,
    "global_block": "attention",
    "sparse_state_local_window": 32,
    "sparse_state_dilated_offsets": [32, 48, 64, 96],
    "sparse_state_chunk_size": 16,
    "mtp_depth": 0,
    "patch_unit_buckets": 0,
    "patch_prediction": true,
    "patch_prediction_stride": 1,
    "patch_prediction_mode": "autoregressive",
    "patch_prediction_context": "global",
    "patch_prediction_detach_context": false,
    "patch_generation_width": 80,
    "patch_generation_context": 0,
    "tie_byte_embeddings": false,
    "context_buckets": 0,
    "context_order": 3,
    "transition_logit_scale": 1.0,
    "context_logit_scale": 1.0,
    "domain_cache_order": 0,
    "domain_cache_logit_scale": 0.0,
    "domain_cache_override": false,
    "copy_transducer": false,
    "trainable_prior_gates": false,
    "trainable_transition_head": true,
    "trainable_context_head": true,
    "repeat_suppression_window": 0,
    "repeat_suppression_scale": 0.0,
    "trainable_repeat_suppression": false,
    "modern_blocks": true,
    "fused_attention": true
  },
  "training": {
    "device": "cuda",
    "seed": 13061,
    "matmul_precision": "high",
    "seq_len": 256,
    "micro_batch_size": 16,
    "grad_accum_steps": 1,
    "steps": 2000,
    "lr": 0.000015,
    "min_lr": 0.000002,
    "warmup_steps": 80,
    "lr_decay_steps": 2000,
    "weight_decay": 0.0,
    "patch_prediction_loss_weight": 0.12,
    "answer_loss_weight": 12.0,
    "answer_only_loss": false,
    "answer_marker": "Answer:",
    "log_interval": 100,
    "save_interval": 500,
    "save_optimizer": false,
    "keep_last_n": 2,
    "metrics_path": "training_metrics.json",
    "read_block_bytes": 1048576,
    "include_suffixes": [".jsonl", ".json", ".txt", ".md", ".csv"],
    "data_mix": [
      {
        "name": "lm_replay",
        "weight": 0.74,
        "include_suffixes": [".jsonl", ".json", ".txt", ".md", ".csv"],
        "data_roots": [
          "./data/game_domains/ember-road.companion_train_expanded_v1.txt",
          "./data/game_domains/ember-road.companion_train_expanded_v1.txt",
          "./data/game_domains/ember-road.companion_train_expanded_v1.txt",
          "./data/game_domains/ember-road.companion_responses.txt",
          "./data/game_domains/ember-road.instructions.txt",
          "./data/game_domains/ember-road.rulebook.repeated.txt",
          "./data/curriculum/companion_dialogue_curriculum.txt",
          "./data/curriculum/english_school_curriculum.txt",
          "../layercakeogwithdecoder/data/v6/redpajama_english_train.jsonl"
        ]
      },
      {
        "name": "question_relevance",
        "weight": 0.13,
        "include_suffixes": [".jsonl"],
        "row_preserve_jsonl_examples": true,
        "data_roots": ["data/question_relevance/question_relevance_train.jsonl"]
      },
      {
        "name": "schema_action_grounding",
        "weight": 0.13,
        "include_suffixes": [".jsonl"],
        "row_preserve_jsonl_examples": true,
        "data_roots": ["data/schema_action_domain/train.jsonl"]
      }
    ],
    "eval_data_roots": [
      "../layercakeogwithdecoder/data/v6/redpajama_english_eval.jsonl"
    ],
    "eval_bytes": 1000000,
    "eval_batches": 32,
    "eval_seed": 13062,
    "resume_from": "runs_experiment/breakthrough_northstar_patch4_transprior_b32_seed9011_polish5000.pt",
    "out_dir": "runs_experiment/northstar_v6_patch4_grounded_mix_layercake"
  }
