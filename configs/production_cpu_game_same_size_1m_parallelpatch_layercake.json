{
  "name": "production_cpu_game_same_size_1m_parallelpatch_layercake",
  "description": "Experimental 1M-class LayerCake candidate using the main-path parallel_patch decoder.",
  "model": {
    "patch_size": 8,
    "d_byte": 32,
    "d_model": 128,
    "d_abi": 128,
    "layers": 4,
    "heads": 4,
    "max_patches": 64,
    "continuous_local": false,
    "direct_global_context": true,
    "local_decoder": "parallel_patch",
    "local_layers": 0,
    "conv_layers": 0,
    "local_width": 192,
    "modern_blocks": true,
    "fused_attention": true,
    "local_window": 32,
    "dropout": 0.05,
    "qk_norm": true,
    "global_block": "sparse_state_patch",
    "sparse_state_local_window": 16,
    "sparse_state_dilated_offsets": [16, 24, 32, 48],
    "sparse_state_chunk_size": 8
  },
  "training": {
    "device": "cuda",
    "matmul_precision": "high",
    "seq_len": 256,
    "micro_batch_size": 4,
    "grad_accum_steps": 1,
    "steps": 2000,
    "lr": 0.0004,
    "min_lr": 0.00008,
    "warmup_steps": 100,
    "lr_decay_steps": 2000,
    "weight_decay": 0.01,
    "log_interval": 50,
    "save_interval": 2000,
    "keep_last_n": 1,
    "save_optimizer": false,
    "metrics_path": "training_metrics.json",
    "read_block_bytes": 1048576,
    "include_suffixes": [".jsonl", ".json", ".txt", ".md", ".csv"],
    "data_roots": [
      "../layercakeogwithdecoder/data/v6/redpajama_english_train.jsonl",
      "./data/curriculum/english_school_curriculum.txt",
      "./data/curriculum/companion_dialogue_curriculum.txt"
    ],
    "out_dir": "runs_experiment/production_cpu_game_same_size_1m_parallelpatch_layercake"
  }
}
