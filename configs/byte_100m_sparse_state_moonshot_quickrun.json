{
  "name": "layercake_byte_100m_sparse_state_moonshot_quickrun",
  "description": "100M-class LayerCake quickrun for moonshot comparison against a 500M BPE transformer",
  "model": {
    "patch_size": 2,
    "d_byte": 64,
    "d_model": 704,
    "d_abi": 256,
    "layers": 15,
    "heads": 11,
    "max_patches": 256,
    "continuous_local": false,
    "direct_global_context": true,
    "local_decoder": "conv",
    "local_layers": 1,
    "conv_layers": 2,
    "local_width": 528,
    "modern_blocks": true,
    "fused_attention": true,
    "local_window": 64,
    "patch_unit_buckets": 0,
    "dropout": 0.05,
    "qk_norm": true,
    "global_block": "sparse_state_patch",
    "sparse_state_local_window": 32,
    "sparse_state_dilated_offsets": [32, 48, 64, 96],
    "sparse_state_chunk_size": 16
  },
  "training": {
    "device": "cuda",
    "matmul_precision": "high",
    "dataloader_workers": 2,
    "pin_memory": true,
    "persistent_workers": true,
    "compile_model": false,
    "optimizer_fused": true,
    "seq_len": 512,
    "micro_batch_size": 1,
    "grad_accum_steps": 2,
    "steps": 30,
    "lr": 0.00016,
    "min_lr": 0.00004,
    "warmup_steps": 4,
    "lr_decay_steps": 30,
    "weight_decay": 0.01,
    "log_interval": 5,
    "save_interval": 30,
    "keep_last_n": 1,
    "save_optimizer": false,
    "metrics_path": "training_metrics.json",
    "throughput_guard": {
      "warmup_steps": 10,
      "max_projected_hours": 0.5,
      "abort_on_fail": false
    },
    "read_block_bytes": 1048576,
    "include_suffixes": [".jsonl", ".json", ".txt", ".md", ".csv"],
    "data_roots": [
      "../layercakeogwithdecoder/data/v6/redpajama_english_train.jsonl",
      "./data/curriculum/english_school_curriculum.txt",
      "./data/curriculum/companion_dialogue_curriculum.txt"
    ],
    "out_dir": "runs_experiment/byte_100m_sparse_state_moonshot_quickrun"
  }
}
