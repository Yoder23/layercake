# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/
.env/

# PyTorch checkpoints (can be very large -- publish as release assets if needed)
*.pt
*.pth
*.ckpt
checkpoints/
runs/
runs_experiment/

# Token data arrays (pre-tokenized corpora)
data/tokens/
*.npy

# Tokenizer model (user-provided)
tokenizer/*.model
tokenizer/*.vocab

# Jupyter
.ipynb_checkpoints/
# Track the demo notebook but ignore checkpoints and scratch notebooks
*.ipynb
!notebooks/layercake_demo.ipynb

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# Generated compiler/runtime caches (never release source artifacts)
.cache/
.i/
.t/
.torchinductor_cache/
.torchinductor_cache_serial/
.triton_cache/
.triton_cache_serial/
.datasets_cache/

# Downloaded/generated V2 corpora and trained checkpoints are reproducible
# artifacts, not source. Their manifests and evidence hashes are committed.
data/moonshot/v2/**/*.bin
data/moonshot/v2/**/manifest.json

# Logs
*.log
*.err

# Research outputs: keep only the locked v22 evidence. Tracked historical
# evidence remains tracked; newly generated exploratory output stays local.
